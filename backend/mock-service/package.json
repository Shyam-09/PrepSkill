{
  "name": "mock-service",
  "version": "1.0.0",
  "description": "Mock tests, auto-grading and leaderboards",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prepskill/common": "^1.0.14",
    "@prisma/client": "^5.13.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "express-validator": "^7.3.1",
    "amqplib": "^0.10.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "@types/amqplib": "^0.10.7",
    "jsonwebtoken": "^9.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ]
  }
}
